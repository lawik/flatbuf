// Sample FlatBuffers schema for Phase 1 round-trip tests.
namespace MyGame.Sample;

enum Color : byte { Red = 0, Green, Blue = 2 }

struct Vec3 {
  x: float;
  y: float;
  z: float;
}

table Weapon {
  name: string;
  damage: short;
}

table Monster {
  pos: Vec3;
  mana: short = 150;
  hp: short = 100;
  name: string;
  inventory: [ubyte];
  color: Color = Blue;
  weapons: [Weapon];
}

root_type Monster;
